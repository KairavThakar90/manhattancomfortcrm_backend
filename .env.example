# --- Neon Postgres ---
# Get this from your Neon dashboard (use the "pooled connection" string)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# --- JWT auth for YOUR app ---
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- SellerCloud ---
# Confirmed from your working Apps Script - this is your real tenant server.
SELLERCLOUD_BASE_URL=https://cd.api.sellercloud.com/rest
SELLERCLOUD_USERNAME=your_sellercloud_username
SELLERCLOUD_PASSWORD=your_sellercloud_password
# The saved PO view/filter ID your Apps Script pulls from (GetAllByView?viewID=25)
SELLERCLOUD_PO_VIEW_ID=25

# --- CORS ---
FRONTEND_ORIGIN=https://manhattancomfortcrm.vercel.app
